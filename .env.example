# Flask-Umgebung: development | production
FLASK_ENV=development

# WICHTIG: Langen, zufälligen String verwenden!
SECRET_KEY=change-me-to-a-long-random-secret-key

# Postgres-Passwort (wird von Docker Compose und lokal verwendet)
POSTGRES_PASSWORD=change-me

# Datenbankverbindung für lokale Entwicklung (Flask direkt):
# → zeigt auf den Docker-Postgres-Container (Port 5432 ist exponiert)
DATABASE_URL=postgresql://wkoss:change-me@localhost:5432/wasserklar
#
# Im Docker-Deployment überschreibt docker-compose.yml diese Variable
# automatisch mit dem internen Hostname "postgres" — hier nichts ändern nötig.
#
# Alternativ SQLite (ohne Docker-Postgres, nur für schnelle Einzeltests):
# DATABASE_URL=sqlite:///instance/wg.db

# Name und Kontakt der Wassergenossenschaft (erscheint auf Rechnungen)
WG_NAME=Wassergenossenschaft Musterdorf
WG_ADDRESS=Musterstraße 1\n1234 Musterdorf
WG_IBAN=AT12 3456 7890 1234 5678
WG_BIC=KSDFSDKKXXX
WG_EMAIL=office@wg-musterdorf.at
WG_PHONE=+43 1234 5678

# E-Mail-Einstellungen (für Rechnungsversand)
MAIL_SERVER=smtp.example.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=office@wg-musterdorf.at
MAIL_PASSWORD=your-email-password
MAIL_DEFAULT_SENDER=office@wg-musterdorf.at
