FLASK_ENV=production

# WICHTIG: Langen, zufälligen String verwenden!
SECRET_KEY=change-me-to-a-long-random-secret-key

# Datenbankverbindung (Standard: SQLite für lokale Entwicklung)
# Für PostgreSQL (Docker mit bundled DB):
# DATABASE_URL=postgresql://wg:wg@localhost:5432/wgbuchhaltung
# POSTGRES_PASSWORD=sicheres-passwort-hier-eintragen
#
# Für MariaDB (z.B. Synology NAS – externe MariaDB):
# DATABASE_URL=mysql+pymysql://wg:passwort@localhost:3306/wgbuchhaltung?charset=utf8mb4

# Name und Kontakt der Wassergenossenschaft (erscheint auf Rechnungen)
WG_NAME=Wassergenossenschaft Musterdorf
WG_ADDRESS=Musterstraße 1\n1234 Musterdorf
WG_IBAN=AT12 3456 7890 1234 5678
WG_BIC=KSDFSDKKXXX
WG_EMAIL=office@wg-musterdorf.at
WG_PHONE=+43 1234 5678

# E-Mail-Einstellungen (für Rechnungsversand)
MAIL_SERVER=smtp.example.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=office@wg-musterdorf.at
MAIL_PASSWORD=your-email-password
MAIL_DEFAULT_SENDER=office@wg-musterdorf.at
